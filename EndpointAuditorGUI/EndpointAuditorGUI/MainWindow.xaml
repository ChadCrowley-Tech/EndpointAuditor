<Window x:Class="EndpointAuditorGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EndpointAuditorGUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Posture Summary -->
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,30,0">
            <TextBlock Text="EndpointAuditor" FontSize="28" FontWeight="Bold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
            <TextBlock Text="Enterprise Dashboard" FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <Border Background="#1E293B" CornerRadius="100" Width="180" Height="180" Margin="0,0,0,30">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txtScore" Text="0/5" FontSize="48" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtOverallStatus" Text="READY" FontSize="18" FontWeight="SemiBold" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Button x:Name="btnRunAudit" Content="INITIATE SCAN" Height="45" Width="180" 
                Background="#10B981" Foreground="#022C22" FontWeight="Bold" FontSize="16" 
                BorderThickness="0" Cursor="Hand" Click="BtnRunAudit_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!-- Right Panel: Threat Feed Checklist -->
        <Border Grid.Column="1" Background="#111827" CornerRadius="12" BorderBrush="#1E293B" BorderThickness="2" Padding="30">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="System Telemetry" FontSize="22" FontWeight="Bold" Margin="0,0,0,25" Foreground="#E2E8F0"/>

                <!-- Check 1 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Windows Defender Real-Time Engine" FontSize="16" Foreground="#CBD5E1"/>
                    <TextBlock x:Name="statusDefender" Grid.Column="1" Text="PENDING" FontSize="16" FontWeight="Bold" Foreground="#475569"/>
                </Grid>

                <!-- Check 2 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Firewall Domain/Private/Public Profiles" FontSize="16" Foreground="#CBD5E1"/>
                    <TextBlock x:Name="statusFirewall" Grid.Column="1" Text="PENDING" FontSize="16" FontWeight="Bold" Foreground="#475569"/>
                </Grid>

                <!-- Check 3 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="User Account Control (UAC) Integrity" FontSize="16" Foreground="#CBD5E1"/>
                    <TextBlock x:Name="statusUAC" Grid.Column="1" Text="PENDING" FontSize="16" FontWeight="Bold" Foreground="#475569"/>
                </Grid>

                <!-- Check 4 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Legacy SMBv1 Server Protocol" FontSize="16" Foreground="#CBD5E1"/>
                    <TextBlock x:Name="statusSMB" Grid.Column="1" Text="PENDING" FontSize="16" FontWeight="Bold" Foreground="#475569"/>
                </Grid>

                <!-- Check 5 -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Default Guest Account Configuration" FontSize="16" Foreground="#CBD5E1"/>
                    <TextBlock x:Name="statusGuest" Grid.Column="1" Text="PENDING" FontSize="16" FontWeight="Bold" Foreground="#475569"/>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</Window>
