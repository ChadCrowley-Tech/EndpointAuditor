<Window x:Class="EndpointAuditorGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EndpointAuditor V3.0" Height="750" Width="1200"
        
        FontFamily="Consolas">

    <Window.Background>
        <ImageBrush ImageSource="C:\Users\Owner\OneDrive\Pictures\Screenshots\GUIBackground20.jfif" Stretch="Fill" Opacity="0.8" >
            <ImageBrush.RelativeTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" CenterY="0.5" CenterX="0.5"/>
            </ImageBrush.RelativeTransform>
        </ImageBrush>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarSurface}" BorderBrush="#2D2844" BorderThickness="0,0,1,0" Opacity="0.8">
            <StackPanel Margin="20">
                <TextBlock Text="SMART_AUDIT" Style="{StaticResource GlowingTitle}" Foreground="{StaticResource ColorNetwork}" FontSize="24" Margin="0,10,0,40"/>

                <TextBlock Text="Menu" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,10"/>
                <TextBlock Text="► Dashboard" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="14" Margin="0,10"/>
                <TextBlock Text="  Data Security-Phase 4" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,10"/>
                <TextBlock Text="  User Behavior-Phase 4" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,10"/>
                <TextBlock Text="  Threat Intel -Phase 4" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,10"/>

                <Border Background="{StaticResource ColorFuture}" CornerRadius="12" Padding="15" Margin="0,25,0,0" Opacity="0.7">
                    <StackPanel>
                        <TextBlock Text="Ready to Scan" Foreground="White" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="Initialize all modules." Foreground="#D1C4E9" FontSize="11" Margin="0,5,0,15" TextWrapping="Wrap"/>
                        <Button x:Name="BtnRunAll" Content="START AUDIT" Style="{StaticResource CyberButton}" Click="BtnRunAll_Click" Background="{StaticResource ColorNetwork}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Dashboard Overview" Style="{StaticResource GlowingTitle}" Foreground="{StaticResource TextPrimary}" FontSize="28" Margin="0,0,0,20"/>

            <Grid Grid.Row="1" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource ColorNetwork}" CornerRadius="12" Padding="20" Margin="0,0,15,0" Opacity="0.7">
                    <StackPanel>
                        <TextBlock Text="Network Status" Style="{StaticResource UniversalCardText}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="Monitoring 3 Vectors" Style="{StaticResource UniversalCardText}" FontSize="11" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{StaticResource ColorExecution}" CornerRadius="12" Padding="20" Margin="0,0,15,0" Opacity="0.7">
                    <StackPanel>
                        <TextBlock Text="Execution Policy" Style="{StaticResource UniversalCardText}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="Monitoring 4 Vectors" Style="{StaticResource UniversalCardText}" FontSize="11" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{StaticResource ColorIdentity}" CornerRadius="12" Padding="20" Margin="0,0,15,0" Opacity="0.7">
                    <StackPanel>
                        <TextBlock Text="Identity &amp; Data" Style="{StaticResource UniversalCardText}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="Monitoring 3 Vectors" Style="{StaticResource UniversalCardText}" FontSize="11" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="{StaticResource ColorFuture}" CornerRadius="12" Padding="20" Opacity="0.7">
                    <StackPanel>
                        <TextBlock Text="Advanced Telemetry" Style="{StaticResource UniversalCardText}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="Pending Phase 4" Style="{StaticResource UniversalCardText}" FontSize="11" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0" Opacity="0.8">
                        <TextBlock Text="[ NETWORK LOGIC ]" Style="{StaticResource GlowingTitle}" Foreground="{StaticResource ColorNetwork}" FontSize="16" Margin="0,0,0,15"/>

                        <Border Style="{StaticResource CompactCard}">
                            <StackPanel>
                                <TextBlock Text="Firewall Profiles" Style="{StaticResource UniversalCardText}" FontSize="13"/>
                                <TextBlock x:Name="TxtFirewall" Text="Awaiting Scan..." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,3,0,10"/>
                                <Expander Header="How to Fix" Foreground="{StaticResource TextSecondary}" FontSize="11">
                                    <TextBlock Text="Open Windows Defender Firewall and ensure both Private and Public network settings are set to ON." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CompactCard}">
                            <StackPanel>
                                <TextBlock Text="SMBv1 Protocol" Style="{StaticResource UniversalCardText}" FontSize="13"/>
                                <TextBlock x:Name="TxtSMBv1" Text="Awaiting Scan..." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,3,0,10"/>
                                <Expander Header="How to Fix" Foreground="{StaticResource TextSecondary}" FontSize="11">
                                    <TextBlock Text="Open 'Turn Windows features on or off'. Uncheck 'SMB 1.0/CIFS Server'. Reboot." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CompactCard}">
                            <StackPanel>
                                <TextBlock Text="LLMNR Resolution" Style="{StaticResource UniversalCardText}" FontSize="13"/>
                                <TextBlock x:Name="TxtLLMNR" Text="Awaiting Scan..." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,3,0,10"/>
                                <Expander Header="How to Fix" Foreground="{StaticResource TextSecondary}" FontSize="11">
                                    <TextBlock Text="Regedit: HKEY_LOCAL_MACHINE\SOFTWARE\Policies\Microsoft\Windows NT\DNSClient. Create DWORD EnableMulticast = 0." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </Expander>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,15,0" Opacity="0.8">
                        <TextBlock Text="[ EXECUTION LOGIC ]" Style="{StaticResource GlowingTitle}" Foreground="{StaticResource ColorExecution}" FontSize="16" Margin="0,0,0,15"/>

                        <Border Style="{StaticResource CompactCard}">
                            <StackPanel>
                                <TextBlock Text="Defender Anti-Virus" Style="{StaticResource UniversalCardText}" FontSize="13"/>
                                <TextBlock x:Name="TxtDefender" Text="Awaiting Scan..." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,3,0,10"/>
                                <Expander Header="How to Fix" Foreground="{StaticResource TextSecondary}" FontSize="11">
                                    <TextBlock Text="Open Windows Security. Enable Real-time protection and Tamper Protection." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CompactCard}">
                            <StackPanel>
                                <TextBlock Text="Exec Policy" Style="{StaticResource UniversalCardText}" FontSize="13"/>
                                <TextBlock x:Name="TxtExecPolicy" Text="Awaiting Scan..." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,3,0,10"/>
                                <Expander Header="How to Fix" Foreground="{StaticResource TextSecondary}" FontSize="11">
                                    <TextBlock Text="Run PowerShell as Admin: Set-ExecutionPolicy Restricted" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CompactCard}">
                            <StackPanel>
                                <TextBlock Text="Script Logging" Style="{StaticResource UniversalCardText}" FontSize="13"/>
                                <TextBlock x:Name="TxtScriptLogging" Text="Awaiting Scan..." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,3,0,10"/>
                                <Expander Header="How to Fix" Foreground="{StaticResource TextSecondary}" FontSize="11">
                                    <TextBlock Text="Regedit: HKEY_LOCAL_MACHINE\SOFTWARE\Policies\Microsoft\Windows\PowerShell\ScriptBlockLogging. Create DWORD EnableScriptBlockLogging = 1." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CompactCard}">
                            <StackPanel>
                                <TextBlock Text="USB AutoRun" Style="{StaticResource UniversalCardText}" FontSize="13"/>
                                <TextBlock x:Name="TxtAutoRun" Text="Awaiting Scan..." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,3,0,10"/>
                                <Expander Header="How to Fix" Foreground="{StaticResource TextSecondary}" FontSize="11">
                                    <TextBlock Text="Regedit: HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\Explorer. Create DWORD NoDriveTypeAutoRun = 255 (Decimal)." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </Expander>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,0,0" Opacity="0.8">
                        <TextBlock Text="[ IDENTITY LOGIC ]" Style="{StaticResource GlowingTitle}" Foreground="{StaticResource ColorIdentity}" FontSize="16" Margin="0,0,0,15"/>

                        <Border Style="{StaticResource CompactCard}">
                            <StackPanel>
                                <TextBlock Text="User Account Control" Style="{StaticResource UniversalCardText}" FontSize="13"/>
                                <TextBlock x:Name="TxtUAC" Text="Awaiting Scan..." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,3,0,10"/>
                                <Expander Header="How to Fix" Foreground="{StaticResource TextSecondary}" FontSize="11">
                                    <TextBlock Text="Search 'Change User Account Control settings'. Drag slider up to at least the default level." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CompactCard}">
                            <StackPanel>
                                <TextBlock Text="Guest Account" Style="{StaticResource UniversalCardText}" FontSize="13"/>
                                <TextBlock x:Name="TxtGuest" Text="Awaiting Scan..." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,3,0,10"/>
                                <Expander Header="How to Fix" Foreground="{StaticResource TextSecondary}" FontSize="11">
                                    <TextBlock Text="Run Command Prompt as Admin: net user guest /active:no" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CompactCard}">
                            <StackPanel>
                                <TextBlock Text="BitLocker Encryption" Style="{StaticResource UniversalCardText}" FontSize="13"/>
                                <TextBlock x:Name="TxtBitLocker" Text="Awaiting Scan..." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,3,0,10"/>
                                <Expander Header="How to Fix" Foreground="{StaticResource TextSecondary}" FontSize="11">
                                    <TextBlock Text="Search 'Manage BitLocker'. Locate Drive (C:) and select 'Turn on BitLocker'. (Requires Pro/Enterprise)." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </Expander>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>